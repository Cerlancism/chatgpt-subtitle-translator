# -- Required ------------------------------------------------ 

# OpenAI API key — https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# -- Rate Limits ------------------------------------------------
# See https://platform.openai.com/docs/guides/rate-limits

# Maximum requests per minute for the translation API (default: 60)
OPENAI_API_RPM=500

# Maximum requests per minute for the moderation endpoint (default: falls back to OPENAI_API_RPM)
# OPENAI_API_MODERATOR_RPM=60

# -- Custom API Provider ------------------------------------------------
# Override the base URL to use any OpenAI-compatible provider

# OpenAI (default, no need to set)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama running locally
# OPENAI_BASE_URL=http://localhost:11434/v1

# Proxy ------------------------------------------------

# HTTP_PROXY=http://user:pass@proxy.example.com:8080
# HTTPS_PROXY=http://user:pass@proxy.example.com:8080
